generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 1. User Management & RBAC
model User {
  id           String          @id @default(cuid())
  username     String          @unique
  passwordHash String
  role         String          @default("WAREHOUSE_STAFF")
  isActive     Boolean         @default(true)
  permissions  String          @default("[]") // JSON array of Permission enum values
  movements    StockMovement[]
  createdAt    DateTime        @default(now())
}

// 2. Product Catalogue
model Product {
  id          String          @id @default(cuid())
  sku         String          @unique
  name        String
  description String?
  category    String?
  unit        String          @default("Cái")
  minQuantity Int             @default(0)
  imageUrl    String?
  stocks      Inventory[]
  movements   StockMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// 3. Warehouse Virtual Coordinate System (3D Map)
model Location {
  id            String          @id @default(cuid())
  label         String          @unique
  x             Int
  y             Int
  z             Int
  status        String          @default("AVAILABLE") // AVAILABLE, FULL, RESERVED
  stocks        Inventory[]
  movements     StockMovement[] @relation("LocationMovements")
  fromMovements StockMovement[] @relation("FromLocationMovements")
  createdAt     DateTime        @default(now())
}

// 4. Actual Inventory (N-N between Product & Location)
model Inventory {
  id         String   @id @default(cuid())
  productId  String
  locationId String
  quantity   Int      @default(0)

  product    Product  @relation(fields: [productId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
}

// 5. Stock Movement Log / Voucher (Audit Trail)
model StockMovement {
  id             String    @id @default(cuid())
  type           String    // IN, OUT, TRANSFER
  quantity       Int
  productId      String
  locationId     String
  userId         String?
  voucherStatus  String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy     String?   // userId of approver
  approvedAt     DateTime?
  note           String?
  fromLocationId String?   // source location for TRANSFER movements

  product        Product   @relation(fields: [productId], references: [id])
  location       Location  @relation("LocationMovements", fields: [locationId], references: [id])
  fromLocation   Location? @relation("FromLocationMovements", fields: [fromLocationId], references: [id])
  user           User?     @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
}
